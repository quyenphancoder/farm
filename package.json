{
  "name": "htmx-phaser-farm",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24.16.0"
  },
  "scripts": {
    "build:css": "tailwindcss -i ./public/tailwind.input.css -o ./public/tailwind.css --minify",
    "watch:css": "tailwindcss -i ./public/tailwind.input.css -o ./public/tailwind.css --watch",
    "predev": "npm run build:css",
    "dev": "node --watch backend/server.js",
    "prestart": "npm run build:css",
    "start": "node backend/server.js"
  },
  "dependencies": {
    "express": "^5.1.0",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.3.3",
    "tailwindcss": "^4.3.3"
  }
}
